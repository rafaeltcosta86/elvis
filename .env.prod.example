# Elvis — Production Environment Variables
# Copy to .env.prod and fill in real values. NEVER commit .env.prod to git.

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://elvis:STRONG_PASSWORD@postgres:5432/elvis
POSTGRES_USER=elvis
POSTGRES_PASSWORD=STRONG_PASSWORD
POSTGRES_DB=elvis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:@redis:6379

# ── App ───────────────────────────────────────────────────────────────────────
OWNER_PHONE=551199999999          # Your WhatsApp number (E.164 format)
JOBS_ENABLED=true
SEND_ENABLED=true                 # Set false to dry-run all email sends

# ── NanoClaw (WhatsApp) ───────────────────────────────────────────────────────
WEBHOOK_SECRET=replace_with_secure_random_string
NANOCLAW_API_URL=https://api.nanoclaw.app
NANOCLAW_API_KEY=your_nanoclaw_api_key

# ── OAuth encryption (AES-256-GCM) ───────────────────────────────────────────
# Generate: openssl rand -hex 32
OAUTH_ENC_KEY=replace_with_64_char_hex_string

# ── Microsoft Graph (Outlook Calendar + Mail) ─────────────────────────────────
MICROSOFT_TENANT_ID=your_tenant_id
MICROSOFT_CLIENT_ID=your_client_id
MICROSOFT_CLIENT_SECRET=your_client_secret

# ── Gmail ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Email classifier config ───────────────────────────────────────────────────
KNOWN_CONTACT_DOMAINS=mckinsey.com,gmail.com
IMPORTANT_KEYWORDS=urgente,ação necessária,prazo,aprovação

# ── Caddy / domain ───────────────────────────────────────────────────────────
ELVIS_DOMAIN=elvis.yourdomain.com

# ── Alerts ────────────────────────────────────────────────────────────────────
QUEUE_STUCK_THRESHOLD=20          # Alert when waiting+active jobs exceed this
